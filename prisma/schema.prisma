generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String
  content          String
  icon             String
  published        Boolean  @default(false)
  isFeatured       Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Solution {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String
  content          String
  icon             String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ProjectCategory {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  projects Project[]
}

model Project {
  id            String           @id @default(cuid())
  title         String
  slug          String           @unique
  summary       String
  content       String
  coverImage    String?
  gallery       String[]
  videoUrl      String?
  projectUrl    String?
  clientName    String?
  sector        String?
  technologies  String[]
  resultMetrics String?
  isFeatured    Boolean          @default(false)
  published     Boolean          @default(false)
  categoryId    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  category      ProjectCategory? @relation(fields: [categoryId], references: [id])
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String
  slug  String     @unique
  posts BlogPost[]
}

model BlogPost {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String
  content        String
  coverImage     String?
  readingTime    Int           @default(5)
  published      Boolean       @default(false)
  featured       Boolean       @default(false)
  categoryId     String?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  category       BlogCategory? @relation(fields: [categoryId], references: [id])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("Genel")
  page      String   @default("global")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(cuid())
  fullName    String
  title       String
  bio         String?
  avatar      String?
  linkedinUrl String?
  githubUrl   String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String
  title     String
  quote     String
  avatar    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model QuoteRequest {
  id                  String         @id @default(cuid())
  fullName            String
  email               String
  phone               String?
  company             String?
  projectType         ProjectType
  budgetRange         BudgetRange
  targetPlatform      TargetPlatform
  deliveryExpectation String?
  description         String
  integrations        String?
  hasExistingSystem   Boolean        @default(false)
  isRead              Boolean        @default(false)
  createdAt           DateTime       @default(now())
}

model AppointmentRequest {
  id        String   @id @default(cuid())
  service   String
  date      String
  time      String
  name      String
  phone     String?
  email     String?
  message   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AvailabilityRule {
  id           String   @id @default(cuid())
  dayOfWeek    Int
  isOpen       Boolean  @default(true)
  startTime    String
  endTime      String
  slotDuration Int      @default(30)
  service      String   @default("all")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([dayOfWeek, service])
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      String
  service   String   @default("all")
  reason    String?
  createdAt DateTime @default(now())

  @@unique([date, service])
}

model BlockedTimeSlot {
  id        String   @id @default(cuid())
  date      String
  time      String
  service   String   @default("all")
  reason    String?
  createdAt DateTime @default(now())

  @@unique([date, time, service])
}

model SiteSetting {
  id                  String   @id @default(cuid())
  siteName            String   @default("Arillasoft")
  siteDescription     String?
  contactEmail        String?
  contactPhone        String?
  address             String?
  linkedinUrl         String?
  githubUrl           String?
  instagramUrl        String?
  twitterUrl          String?
  logoPath            String?
  faviconPath         String?
  heroTitle           String   @default("Restoranınız İçin|Akıllı Dijital Menü Sistemi")
  heroSubtitle        String   @default("QR kod ile anında erişilen, anlık güncellenebilen, çok dilli dijital menü çözümü. Müşteri deneyimini dönüştürün, maliyetleri azaltın.")
  heroPrimaryButton   String   @default("Demo Talep Et")
  heroSecondaryButton String   @default("Tüm Hizmetler")
  homepageIntro       String   @default("Web'den mobilye, backend'den UI/UX tasarımına — uçtan uca dijital dönüşüm hizmetleri.")
  whyChooseUsTitle    String   @default("QR Menü Sistemi ile|Restoranınızı Dönüştürün")
  whyChooseUsText     String   @default("Masaya QR kodu koyun, müşterileriniz menüye anında ulaşsın. Baskı masrafı yok, güncelleme zahmeti yok.")
  homepageCTA         String   @default("Dijital Dönüşümünüzü|Bugün Başlatın")
  updatedAt           DateTime @updatedAt
}

model AnnouncementBar {
  id                 String    @id @default(cuid())
  name               String    @default("Campaign")
  priority           Int       @default(0)
  enabled            Boolean   @default(false)
  text               String    @default("")
  description        String?
  backgroundColor    String    @default("#dc2626")
  textColor          String    @default("#ffffff")
  dismissible        Boolean   @default(false)
  countdownEnabled   Boolean   @default(false)
  countdownMode      String    @default("fixed")
  startsAt           DateTime?
  expiresAt          DateTime?
  dailyResetHour     Int       @default(0)
  dailyResetMinute   Int       @default(0)
  scrollEnabled      Boolean   @default(false)
  scrollSpeed        String    @default("normal")
  targetMode         String    @default("all")
  targetRoutes       String[]  @default([])
  updatedAt          DateTime  @updatedAt
}

model PartnerLogo {
  id         String   @id @default(cuid())
  name       String
  imagePath  String
  websiteUrl String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum ProjectType {
  WEB_APPLICATION
  MOBILE_APPLICATION
  CUSTOM_SOFTWARE
  UI_UX_DESIGN
  BACKEND_API
  ECOMMERCE
  SAAS
  OTHER
}

enum BudgetRange {
  UNDER_10K
  RANGE_10K_25K
  RANGE_25K_50K
  RANGE_50K_100K
  ABOVE_100K
  UNDECIDED
}

enum TargetPlatform {
  WEB
  IOS
  ANDROID
  BOTH_MOBILE
  DESKTOP
  ALL_PLATFORMS
}
